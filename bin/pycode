#!/bin/bash
# PY_Code Flutter CLI - Encrypted Wrapper

PASSWORD="PY_Code@2026_Secure"
PYCODE_HOME="${HOME}/.pycode"

# دالة المساعدة (مدمجة في الغلاف)
show_help() {
    echo ""
    echo "PY_Code Flutter CLI v1.0.0"
    echo "The Ultimate CLI for Mobile Developers on Termux"
    echo ""
    echo "Usage: pycode <command> [options]"
    echo ""
    echo "Commands:"
    echo "  install <package>     Install packages (flutter, qwen, neovim, etc.)"
    echo "  update                Update PY_Code CLI to latest version"
    echo ""
    echo "Flutter Commands:"
    echo "  flutter init          Initialize cloud builds in Flutter project"
    echo "  flutter doctor        Check system setup for Flutter development"
    echo "  flutter build <type>  Build APK/AAB in the cloud"
    echo "  flutter run web       Run Flutter web server locally"
    echo ""
    echo "Options:"
    echo "  --help, -h            Show this help"
    echo "  --version, -v         Show version"
    echo ""
    echo "Examples:"
    echo "  pycode install flutter"
    echo "  pycode flutter init"
    echo "  pycode flutter build apk --release"
    echo ""
}

# تحميل المكتبات الأساسية (لو موجودة)
if [[ -f "$PYCODE_HOME/lib/core.sh.gpg" ]]; then
    eval "$(gpg --decrypt --batch --passphrase "$PASSWORD" "$PYCODE_HOME/lib/core.sh.gpg" 2>/dev/null)"
fi

main() {
    local command="$1"
    shift 2>/dev/null || true
    
    case "$command" in
        --help|-h|help|"")
            show_help
            ;;
        --version|-v|version)
            echo "PY_Code Flutter CLI v1.0.0"
            ;;
        install)
            echo "📦 Installing: $1"
            echo "Run: pycode install <package>"
            echo ""
            echo "Available: flutter, qwen, oh-my-zsh, shell-tools, neovim, micro, fish, zsh, thefuck"
            ;;
        update)
            echo "🔄 Updating PY_Code Flutter CLI..."
            cd "$PYCODE_HOME" && git pull 2>/dev/null
            echo "✅ Updated to latest version"
            ;;
        flutter)
            local subcommand="$1"
            case "$subcommand" in
                init)
                    echo "🦋 Initializing Flutter cloud build..."
                    ;;
                doctor)
                    echo "🩺 Checking Flutter setup..."
                    ;;
                build)
                    echo "☁️ Building in cloud..."
                    echo "   Target: $1"
                    ;;
                run)
                    echo "🌐 Running Flutter web server..."
                    ;;
                *)
                    echo "Unknown flutter command: $subcommand"
                    echo "Available: init, doctor, build, run"
                    ;;
            esac
            ;;
        *)
            echo "Unknown command: $command"
            show_help
            ;;
    esac
}

main "$@"
